{
  "name": "degree-graph",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "scraper"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "migrate": "node db/migrate.js",
    "seed": "node db/seed.js",
    "scrape": "npm run scrape --workspace=scraper",
    "build": "npm run build --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
